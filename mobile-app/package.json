{
  "name": "antiadhd-mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild:android": "expo prebuild --platform android",
    "native:android": "expo run:android",
    "build:android:debug": "cd android && gradlew.bat assembleDebug",
    "build:android:apk": "cd android && gradlew.bat assembleRelease",
    "build:android:release": "cd android && gradlew.bat bundleRelease"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.7.9",
    "expo": "~52.0.20",
    "expo-asset": "~11.0.1",
    "expo-audio": "~0.3.5",
    "expo-build-properties": "~0.13.3",
    "expo-constants": "~17.0.3",
    "expo-dev-client": "~5.0.20",
    "expo-notifications": "~0.29.14",
    "expo-status-bar": "~2.0.0",
    "expo-system-ui": "~4.0.9",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-android-widget": "^0.17.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@types/react": "~18.3.12",
    "typescript": "~5.3.3"
  }
}
