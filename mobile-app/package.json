{
  "name": "antiadhd-mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "prebuild:android": "expo prebuild --platform android",
    "native:android": "expo run:android",
    "build:android:debug": "cd android && gradlew.bat assembleDebug",
    "build:android:apk": "cd android && gradlew.bat assembleRelease",
    "build:android:release": "cd android && gradlew.bat bundleRelease",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "axios": "^1.7.9",
    "expo": "~53.0.27",
    "expo-asset": "~11.1.7",
    "expo-audio": "~0.4.9",
    "expo-build-properties": "~0.14.8",
    "expo-constants": "~17.1.8",
    "expo-dev-client": "~5.2.4",
    "expo-notifications": "~0.31.5",
    "expo-secure-store": "~14.2.4",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.11",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-android-widget": "^0.17.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3",
    "vitest": "^3.2.4"
  }
}
